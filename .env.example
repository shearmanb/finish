# Copy to .env and fill in. On Railway, set these as service variables.

# Postgres connection (Railway provides DATABASE_URL automatically when you add Postgres).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
# Only needed for `prisma migrate dev` locally (a throwaway second database).
SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME_shadow?schema=public"

# Base64 of a bcrypt hash of your chosen app password.
# Generate: node -e "console.log(Buffer.from(require('bcryptjs').hashSync('YOUR_PASSWORD',10)).toString('base64'))"
APP_PASSWORD_HASH_B64=""

# Random 32+ byte secret for signing the session cookie.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# Directory for uploaded bottle photos. On Railway, mount a persistent volume here.
UPLOAD_DIR="./public/uploads"
